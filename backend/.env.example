# Este arquivo e apenas um modelo.
# Copie para backend/.env para uso local:
# cp backend/.env.example backend/.env

# Chave secreta para assinar os tokens JWT
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Horas ate o token expirar (padrao: 12)
TOKEN_EXPIRE_HOURS=12

# Usuarios do sistema — formato: nome:senha,nome2:senha2
# Troque as senhas antes de publicar!
USERS=admin:TroqueEstaSenha1,ana:OutraSenhaForte2

# URL do Postgres. Em producao na Vercel/Neon, normalmente a integracao
# injeta POSTGRES_URL automaticamente e voce nao precisa repetir aqui.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Tamanho do pool de conexoes do backend
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=5

# Caminho do frontend buildado (opcional, para servir em outro ambiente)
# FRONTEND_DIR=/var/www/zqcuidadoras/frontend/dist

# Caminho opcional do SQLite de origem para a migracao manual
# SQLITE_PATH=backend/cuidarcontrol.db
