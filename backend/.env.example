# Chave secreta para assinar os tokens JWT
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Horas até o token expirar (padrão: 12)
TOKEN_EXPIRE_HOURS=12

# Usuários do sistema — formato: nome:senha,nome2:senha2
# Troque as senhas antes de publicar!
USERS=admin:TroqueEstaSenha1,ana:OutraSenhaForte2

# URL do Postgres. Em produção na Vercel/Neon, normalmente a integração
# injeta POSTGRES_URL automaticamente e você não precisa repetir aqui.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Tamanho do pool de conexões do backend
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=5

# Caminho do frontend buildado (opcional, para servir em outro ambiente)
# FRONTEND_DIR=/var/www/zqcuidadoras/frontend/dist

# Caminho opcional do SQLite de origem para a migração manual
# SQLITE_PATH=backend/cuidarcontrol.db