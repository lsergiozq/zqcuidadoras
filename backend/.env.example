# Chave secreta para assinar os tokens JWT
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Horas até o token expirar (padrão: 12)
TOKEN_EXPIRE_HOURS=12

# Usuários do sistema — formato: nome:senha,nome2:senha2
# Troque as senhas antes de publicar!
USERS=admin:admin123,ana:senha456

# Caminho do banco SQLite (padrão: pasta do backend)
# DB_PATH=/var/www/zqcuidadoras/zqcuidadoras.db

# Caminho do frontend buildado (para servir em produção)
# FRONTEND_DIR=/var/www/zqcuidadoras/frontend/dist
